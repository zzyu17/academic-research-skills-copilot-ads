# Auto-detect text files, normalize line endings to LF on commit
* text=auto

# Shell scripts must use LF
*.sh text eol=lf

# Markdown — LF
*.md text eol=lf

# JavaScript/Node — LF
*.mjs text eol=lf
*.js text eol=lf
*.json text eol=lf

# YAML — LF
*.yml text eol=lf
*.yaml text eol=lf

# Python — LF
*.py text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
